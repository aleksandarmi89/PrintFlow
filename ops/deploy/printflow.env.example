# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Server
SERVER_PORT=8088

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/printflow_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=printflow_app
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_DB_PASSWORD

# Upload paths
APP_UPLOAD_DIR=/opt/printflow/uploads

# Security
MAIL_CRYPT_KEY=CHANGE_ME_BASE64_16_24_OR_32_BYTES

# Public app URL (emails/links)
APP_BASE_URL=https://your-domain.com

# SMTP (if app emails are enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true

# Stripe (optional)
STRIPE_MODE=live
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://your-domain.com/billing/success
STRIPE_CANCEL_URL=https://your-domain.com/billing/cancel
